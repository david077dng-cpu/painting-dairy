# Nano Banana API Key for AI Image Generation
# Get your API key from https://nanobanana.ai
PUBLIC_NANO_BANANA_API_KEY=your-api-key-here

# Anthropic API Key for prompt generation
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Replicate Image Generation
# Get your API token from https://replicate.com/account/api-tokens
# If using OpenAI-compatible proxy, set BASE_URL to full endpoint
REPLICATE_API_TOKEN=your-replicate-api-token-here
REPLICATE_MODEL=stability-ai/sdxl
REPLICATE_BASE_URL=https://api.replicate.com/v1
