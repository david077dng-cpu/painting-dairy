# 生产环境配置
# 部署时复制此文件为 .env 并填写实际值

# 飞书应用配置（必填）
LARK_APP_ID=
LARK_APP_SECRET=

# 飞书 Webhook（可选，用于主动推送消息）
LARK_WEBHOOK_URL=

# 服务器配置
PORT=3000
NODE_ENV=production

# GitHub 配置（可选，用于部署功能）
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# 网站配置
SITE_URL=https://xlilian.art
SITE_NAME=李春晓的个人网站

# 监控配置（分钟）
HEALTH_CHECK_INTERVAL=5
SSL_CHECK_INTERVAL=1440
