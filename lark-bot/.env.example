# 飞书应用配置
# 从飞书开放平台获取: https://open.feishu.cn/app
LARK_APP_ID=xxx
LARK_APP_SECRET=xxxx

# 机器人 Webhook 地址（可选，用于主动推送消息）
LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 服务器配置
PORT=3000

# GitHub 配置（用于部署功能）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-username
GITHUB_REPO=your-repo

# 网站配置
SITE_URL=https://xlilian.art
SITE_NAME=李春晓的个人网站

# 监控配置（分钟）
HEALTH_CHECK_INTERVAL=5
SSL_CHECK_INTERVAL=1440

# WeChat Auto-Sync Configuration
WECHAT_SYNC_ENABLED=true
WECHAT_ARTICLES_JSON_PATH=./data/wechat-articles.json
WECHAT_DEFAULT_CATEGORY=Painting Diary
SYNC_SCHEDULE_CRON=0 9 * * 1
REPORT_CHAT_ID=your_chat_id

# WeChat Official Account Push Notification (auto-sync when new article published)
# 微信公众号自动推送 - 发布新文章时自动同步到网站
WECHAT_PUSH_ENABLED=false
# 在公众号后台 开发 -> 基本配置 设置的 Token
WECHAT_TOKEN=your_wechat_token
# 如果使用加密模式需要 EncodingAESKey，目前暂不支持加密模式
# WECHAT_ENCODING_AES_KEY=your_encoding_aes_key

# Email Notification (send email when sync completes)
# 邮件通知 - 同步完成后发送邮件通知
EMAIL_NOTIFICATION_ENABLED=false
# SMTP 配置 (QQ邮箱示例: host: smtp.qq.com, port: 587, secure: false)
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=your@email.com
EMAIL_SMTP_PASS=your-smtp-password-or-app-password
# 接收通知的邮箱地址
EMAIL_NOTIFICATION_TO=your@email.com
