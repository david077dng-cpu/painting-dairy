---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
const basePath = import.meta.env.BASE_URL;
---
<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <main style="max-width:760px; margin:0 auto; padding:8rem 2rem 4rem;">
    <a href={`${basePath.endsWith('/') ? basePath : `${basePath}/`}posts`} style="font-family:'Inter', 'Noto Sans SC', sans-serif; font-size:0.85rem; color:var(--text-secondary); text-decoration:none; display:inline-flex; align-items:center; gap:0.4rem; margin-bottom:2rem;">
      ← 返回文章列表
    </a>

    <div class="post-header">
      <div style="font-family:'Inter', 'Noto Sans SC', sans-serif; font-size:0.75rem; color:var(--text-secondary); letter-spacing:0.1em; margin-bottom:0.8rem;">
        {frontmatter.date} · {frontmatter.category ?? '随笔'}
        <span id="busuanzi_container_page_pv" style="margin-left: 0.5rem; display:inline;">
          · 阅读 <span id="busuanzi_value_page_pv"></span> 次
        </span>
      </div>
      <h1 style="font-family:'Inter', 'Noto Sans SC', sans-serif; font-size:clamp(1.8rem,3vw,2.8rem); font-weight:700; color:var(--text-primary); line-height:1.3; margin-bottom:1rem;">
        {frontmatter.title}
      </h1>
      {frontmatter.description && (
        <p style="font-size:1.05rem; color:var(--text-secondary); line-height:1.6; border-left:3px solid var(--border-strong); padding-left:1rem;">
          {frontmatter.description}
        </p>
      )}
    </div>

    <article class="prose">
      <slot />
    </article>
  </main>
</BaseLayout>

<style>
  :root {
    --bg-primary: #ffffff;
    --bg-secondary: #f7f6f3;
    --bg-hover: #ebebea;
    --border-subtle: #e9e9e7;
    --border-strong: #d3d3d1;
    --text-primary: #37352f;
    --text-secondary: #787774;
    --text-tertiary: #9b9a97;
    --accent: #2eaadc;
  }
  .post-header {
    padding-bottom: 2rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--border-subtle);
  }
  .prose {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-primary);
  }
  .prose :global(h2) {
    font-family: 'Inter', 'Noto Sans SC', sans-serif;
    font-size: 1.5rem; font-weight: 600;
    color: var(--text-primary); margin: 2.5rem 0 1rem;
  }
  .prose :global(h3) {
    font-family: 'Inter', 'Noto Sans SC', sans-serif;
    font-size: 1.25rem; font-weight: 600;
    color: var(--text-primary); margin: 2rem 0 0.8rem;
  }
  .prose :global(p) { margin-bottom: 1.4rem; }
  .prose :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--border-strong);
    padding: 0.5rem 1.2rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    border-radius: 0 4px 4px 0;
  }
  .prose :global(code) {
    background: var(--bg-secondary); padding: 0.1em 0.4em;
    border-radius: 4px; font-size: 0.9em;
  }
  .prose :global(pre) {
    background: var(--bg-secondary); color: var(--text-primary);
    border: 1px solid var(--border-subtle);
    padding: 1.5rem; border-radius: 8px;
    overflow-x: auto; margin: 1.5rem 0;
  }
  .prose :global(pre code) { background: none; padding: 0; }
  .prose :global(img) {
    width: 100%; border-radius: 8px;
    margin: 1.5rem 0; box-shadow: var(--shadow-small);
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem; margin-bottom: 1.4rem;
  }
  .prose :global(li) { margin-bottom: 0.4rem; }
  .prose :global(hr) { border: none; border-top: 1px solid var(--border-subtle); margin: 2rem 0; }
</style>

<!-- 不蒜子阅读量统计 -->
<script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
