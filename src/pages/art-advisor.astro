---
const title = 'AI 艺术指导 · 李春晓';
const description = '上传照片和手绘作品，AI 帮你分析并提供改进建议';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body>
  <div class="app-container">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar" style="width: 420px;">
      <div class="sidebar-header">
        <div class="brand">
          <div class="brand-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 3v18M3 12h18M7.5 7.5l9 9M16.5 7.5l-9 9" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="brand-text">艺术指导</span>
        </div>
        <div class="header-actions">
          <a href="/" class="home-btn" aria-label="返回主页">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>主页</span>
          </a>
          <button class="sidebar-close" id="sidebarClose" aria-label="关闭侧边栏">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Sources Section -->
      <div class="sources-section">
        <div class="section-header">
          <h2 class="section-title">参考素材</h2>
          <span class="source-badge" id="sourceBadge">0/2</span>
        </div>

        <div class="sources-list" id="sourcesList">
          <!-- Empty State -->
          <div class="empty-state" id="emptyState">
            <div class="empty-illustration">
              <div class="placeholder-stack">
                <div class="placeholder-card card-back"></div>
                <div class="placeholder-card card-front"></div>
              </div>
            </div>
            <p class="empty-title">添加参考素材</p>
            <p class="empty-description">上传原照片和手绘作品，AI 将对比分析并提供改进建议</p>
          </div>

          <!-- Source items will be added here -->
        </div>

        <!-- Add Buttons -->
        <div class="add-buttons">
          <button class="add-btn photo-btn" id="addPhotoBtn">
            <span class="btn-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <path d="M21 15l-5-5L5 21"/>
              </svg>
            </span>
            <span class="btn-text">添加照片</span>
          </button>
          <button class="add-btn drawing-btn" id="addDrawingBtn">
            <span class="btn-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 19l7-7 3 3-7 7-3-3z"/>
                <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
                <path d="M2 2l7.586 7.586"/>
                <circle cx="11" cy="11" r="2"/>
              </svg>
            </span>
            <span class="btn-text">添加手绘</span>
          </button>
        </div>
      </div>

      <!-- Tips Section -->
      <div class="tips-section">
        <div class="tip-card">
          <div class="tip-icon">💡</div>
          <p class="tip-text">上传清晰的照片和手绘作品，可以获得更准确的分析建议</p>
        </div>
      </div>

      <input type="file" id="photoInput" accept="image/*" hidden>
      <input type="file" id="drawingInput" accept="image/*" hidden>
    </aside>

    <!-- Resizer -->
    <div class="resizer" id="resizer"></div>

  <!-- Main Content -->
    <main class="main-content">
      <!-- Mobile Header -->
      <header class="mobile-header">
        <button class="menu-btn" id="menuBtn" aria-label="打开菜单">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"/>
          </svg>
        </button>
        <span class="mobile-title">艺术指导</span>
        <div class="mobile-spacer"></div>
      </header>

      <!-- Chat Container -->
      <div class="chat-container" id="chatContainer">
        <!-- Welcome Screen -->
        <div class="welcome-screen" id="welcomeScreen">
          <div class="welcome-content">
            <div class="welcome-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 3v18M3 12h18M7.5 7.5l9 9M16.5 7.5l-9 9" stroke-linecap="round"/>
              </svg>
            </div>
            <h1 class="welcome-title">AI 艺术指导</h1>
            <p class="welcome-subtitle">上传你的参考照片和手绘作品<br>获得专业的分析和改进建议</p>

            <div class="feature-cards">
              <div class="feature-card">
                <div class="feature-icon">📷</div>
                <span class="feature-text">上传参考照片</span>
              </div>
              <div class="feature-arrow">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="feature-card">
                <div class="feature-icon">✏️</div>
                <span class="feature-text">上传手绘作品</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Messages will appear here -->
        <div class="messages-wrapper" id="messagesWrapper" style="display: none;"></div>
      </div>

      <!-- Input Area -->
      <div class="input-area">
        <div class="input-wrapper">
          <div class="input-avatar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <textarea
            id="messageInput"
            class="message-input"
            placeholder="询问关于作品的建议..."
            rows="1"
          ></textarea>
          <button class="send-btn" id="sendBtn" disabled>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22 2L11 13M22 2l-7 20-4-9-9-7 20-5z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <p class="input-hint">按 Enter 发送，Shift + Enter 换行</p>
      </div>
    </main>
  </div>

  <!-- Overlay for mobile sidebar -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
</body>
</html>

<style>
  /* CSS Reset & Base */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    /* NotebookLM inspired color palette - warm and sophisticated */
    --bg-primary: #FAF8F5;
    --bg-secondary: #F5F1EC;
    --bg-tertiary: #EDE8E1;
    --bg-sidebar: #F7F4F0;

    --text-primary: #1A1A1A;
    --text-secondary: #4A4A4A;
    --text-tertiary: #7A7A7A;
    --text-muted: #9A9A9A;

    --accent-primary: #B87333;
    --accent-secondary: #D4A574;
    --accent-hover: #9A5F2A;
    --accent-light: #F5E6D3;

    --border-light: #E5E0D8;
    --border-medium: #D5D0C8;

    --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.06);
    --shadow-lg: 0 8px 24px rgba(0,0,0,0.08);

    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
    --radius-xl: 24px;
  }

  html, body {
    height: 100%;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-primary);
    background: var(--bg-primary);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* App Container */
  .app-container {
    display: flex;
    height: 100vh;
    overflow: hidden;
  }

  .home-link:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  /* Sidebar */
  .sidebar {
    width: 420px;
    min-width: 320px;
    max-width: 600px;
    background: var(--bg-sidebar);
    border-right: 1px solid var(--border-light);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* Resizer */
  .resizer {
    width: 8px;
    background: linear-gradient(90deg, var(--border-light) 0%, var(--bg-tertiary) 50%, var(--border-light) 100%);
    cursor: col-resize;
    transition: all 0.2s ease;
    flex-shrink: 0;
    position: relative;
    box-shadow: inset -1px 0 2px rgba(0,0,0,0.05);
  }

  .resizer:hover,
  .resizer.active {
    background: linear-gradient(90deg, var(--accent-secondary) 0%, var(--accent-primary) 50%, var(--accent-secondary) 100%);
    box-shadow: inset -1px 0 2px rgba(0,0,0,0.1), 0 0 8px rgba(184, 115, 51, 0.3);
  }

  .resizer::before {
    content: '⋮⋮';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    font-size: 10px;
    letter-spacing: -2px;
    color: var(--text-muted);
    opacity: 0.6;
    line-height: 1;
    pointer-events: none;
  }

  .resizer:hover::before,
  .resizer.active::before {
    color: white;
    opacity: 0.9;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border-light);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .brand-icon {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .brand-text {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.3px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .home-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .home-btn:hover {
    background: var(--accent-light);
    border-color: var(--accent-secondary);
    color: var(--accent-primary);
  }

  .home-btn svg {
    flex-shrink: 0;
  }

  .sidebar-close {
    display: none;
    background: none;
    border: none;
    padding: 6px;
    border-radius: var(--radius-sm);
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .sidebar-close:hover {
    background: var(--bg-tertiary);
    color: var(--text-secondary);
  }

  /* Sources Section */
  .sources-section {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .section-title {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-secondary);
  }

  .source-badge {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-tertiary);
    padding: 2px 8px;
    border-radius: 999px;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 40px 20px;
    border: 2px dashed var(--border-medium);
    border-radius: var(--radius-lg);
    background: var(--bg-primary);
  }

  .empty-illustration {
    margin-bottom: 20px;
  }

  .placeholder-stack {
    position: relative;
    width: 64px;
    height: 64px;
    margin: 0 auto;
  }

  .placeholder-card {
    position: absolute;
    width: 48px;
    height: 56px;
    border-radius: var(--radius-sm);
    border: 2px solid var(--border-medium);
  }

  .card-back {
    background: var(--bg-tertiary);
    transform: rotate(-8deg) translate(-4px, 4px);
  }

  .card-front {
    background: var(--bg-primary);
    transform: rotate(4deg) translate(12px, -2px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-front::after {
    content: '+';
    font-size: 20px;
    color: var(--text-muted);
  }

  .empty-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .empty-description {
    font-size: 13px;
    color: var(--text-tertiary);
    line-height: 1.5;
  }

  /* Source Items */
  .source-item {
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 12px;
    transition: all 0.2s ease;
  }

  .source-item:hover {
    border-color: var(--accent-secondary);
    box-shadow: var(--shadow-sm);
  }

  .source-preview {
    width: 100%;
    max-height: 200px;
    object-fit: contain;
    object-position: center;
    background: linear-gradient(135deg, #f8f8f8 0%, #f0f0f0 100%);
    display: block;
    padding: 8px;
  }

  @media (max-width: 768px) {
    .source-preview {
      max-height: 150px;
    }
  }

  .source-info {
    padding: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .source-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .source-type-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 8px;
    background: var(--accent-light);
    border-radius: var(--radius-sm);
    font-size: 11px;
    font-weight: 600;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .remove-source {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    border-radius: var(--radius-sm);
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .remove-source:hover {
    background: #fee2e2;
    color: #dc2626;
  }

  /* Add Buttons */
  .add-buttons {
    padding: 16px 0;
    border-top: 1px solid var(--border-light);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .add-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    background: var(--bg-primary);
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .add-btn:hover {
    border-color: var(--accent-secondary);
    color: var(--accent-primary);
    background: var(--accent-light);
  }

  .btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Tips Section */
  .tips-section {
    padding: 16px;
    background: linear-gradient(135deg, #f8f6f3 0%, #f0ebe4 100%);
    border-top: 1px solid var(--border-light);
  }

  .tip-card {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .tip-icon {
    font-size: 16px;
    line-height: 1;
    flex-shrink: 0;
  }

  .tip-text {
    font-size: 12px;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  /* Main Content */
  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--bg-primary);
    overflow: hidden;
  }

  /* Mobile Header */
  .mobile-header {
    display: none;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border-light);
    background: var(--bg-primary);
  }

  .menu-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    cursor: pointer;
  }

  .mobile-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .mobile-spacer {
    width: 36px;
  }

  /* Chat Container */
  .chat-container {
    flex: 1;
    overflow-y: auto;
    padding: 24px 32px;
  }

  /* Welcome Screen */
  .welcome-screen {
    min-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .welcome-content {
    text-align: center;
    max-width: 480px;
  }

  .welcome-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 20px;
    background: linear-gradient(135deg, var(--accent-light) 0%, #f5e6d3 100%);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-primary);
  }

  .welcome-title {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 32px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 12px;
    letter-spacing: -0.5px;
  }

  .welcome-subtitle {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }

  .feature-cards {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 16px 20px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
  }

  .feature-icon {
    font-size: 24px;
  }

  .feature-text {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .feature-arrow {
    color: var(--text-tertiary);
  }

  /* Messages */
  .messages-wrapper {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  .message {
    display: flex;
    gap: 12px;
    animation: fadeInUp 0.3s ease;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .message-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-message .message-avatar {
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    color: white;
  }

  .user-message {
    flex-direction: row-reverse;
  }

  .user-message .message-avatar {
    background: var(--bg-tertiary);
    color: var(--text-secondary);
  }

  .message-content {
    flex: 1;
    max-width: calc(100% - 48px);
  }

  .message-bubble {
    padding: 14px 18px;
    border-radius: 18px;
    font-size: 14px;
    line-height: 1.6;
  }

  .ai-message .message-bubble {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border-bottom-left-radius: 4px;
  }

  .user-message .message-bubble {
    background: var(--accent-primary);
    color: white;
    border-bottom-right-radius: 4px;
  }

  .message-bubble p {
    margin: 0 0 0.75em;
  }

  .message-bubble p:last-child {
    margin-bottom: 0;
  }

  .message-bubble ul {
    margin: 0.5em 0;
    padding-left: 1.25em;
  }

  .message-bubble li {
    margin-bottom: 0.25em;
  }

  .message-bubble strong {
    font-weight: 600;
  }

  /* Loading Message */
  .loading-message .message-bubble {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 120px;
  }

  /* Sophisticated Loading Animation */
  .loading-spinner {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .loading-spinner .dot {
    width: 6px;
    height: 6px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    border-radius: 50%;
    animation: sophisticatedBounce 1.4s infinite ease-in-out both;
  }

  .loading-spinner .dot:nth-child(1) { animation-delay: -0.32s; }
  .loading-spinner .dot:nth-child(2) { animation-delay: -0.16s; }
  .loading-spinner .dot:nth-child(3) { animation-delay: 0s; }

  @keyframes sophisticatedBounce {
    0%, 80%, 100% {
      transform: scale(0.6);
      opacity: 0.4;
    }
    40% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .loading-text {
    font-size: 13px;
    color: var(--text-secondary);
    font-style: italic;
  }

  /* Input Area */
  .input-area {
    padding: 16px 32px 24px;
    background: var(--bg-primary);
    border-top: 1px solid var(--border-light);
  }

  .input-wrapper {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: 24px;
    padding: 8px 8px 8px 16px;
    transition: all 0.2s ease;
  }

  .input-wrapper:focus-within {
    border-color: var(--accent-secondary);
    background: var(--bg-primary);
    box-shadow: 0 0 0 3px var(--accent-light);
  }

  .input-avatar {
    width: 28px;
    height: 28px;
    background: var(--bg-tertiary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-tertiary);
    flex-shrink: 0;
    margin-bottom: 4px;
  }

  .message-input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 6px 0;
    font-size: 15px;
    line-height: 1.5;
    color: var(--text-primary);
    resize: none;
    min-height: 28px;
    max-height: 120px;
    font-family: inherit;
  }

  .message-input:focus {
    outline: none;
  }

  .message-input::placeholder {
    color: var(--text-muted);
  }

  .send-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-primary);
    border: none;
    border-radius: 50%;
    color: white;
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .send-btn:hover:not(:disabled) {
    background: var(--accent-hover);
    transform: scale(1.05);
  }

  .send-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .input-hint {
    text-align: center;
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 10px;
  }

  /* Overlay */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(2px);
    z-index: 90;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .sidebar-overlay.active {
    opacity: 1;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .sidebar {
      position: fixed;
      left: 0;
      top: 0;
      bottom: 0;
      z-index: 100;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      box-shadow: var(--shadow-lg);
    }

    .sidebar.open {
      transform: translateX(0);
    }

    .sidebar-close {
      display: flex;
    }

    .sidebar-overlay {
      display: block;
    }

    .mobile-header {
      display: flex;
    }

    .chat-container {
      padding: 16px 20px;
    }

    .input-area {
      padding: 12px 16px 16px;
    }
  }

  @media (max-width: 600px) {
    .welcome-title {
      font-size: 24px;
    }

    .feature-cards {
      flex-direction: column;
      gap: 12px;
    }

    .feature-arrow {
      transform: rotate(90deg);
    }

    .message-bubble {
      padding: 12px 14px;
      font-size: 14px;
    }
  }
</style>

<script>
  // State
  interface Source {
    id: string;
    type: 'photo' | 'drawing';
    url: string;
    name: string;
  }

  let sources: Source[] = [];
  let messages: { role: 'user' | 'ai'; content: string }[] = [];
  let isLoading = false;

  // DOM Elements
  const sidebar = document.getElementById('sidebar')!;
  const resizer = document.getElementById('resizer')!;
  const sidebarOverlay = document.getElementById('sidebarOverlay')!;
  const menuBtn = document.getElementById('menuBtn')!;
  const sidebarClose = document.getElementById('sidebarClose')!;
  const sourcesList = document.getElementById('sourcesList')!;
  const emptyState = document.getElementById('emptyState')!;
  const sourceBadge = document.getElementById('sourceBadge')!;
  const welcomeScreen = document.getElementById('welcomeScreen')!;
  const messagesWrapper = document.getElementById('messagesWrapper')!;
  const messageInput = document.getElementById('messageInput')! as HTMLTextAreaElement;
  const sendBtn = document.getElementById('sendBtn')! as HTMLButtonElement;
  const photoInput = document.getElementById('photoInput')! as HTMLInputElement;
  const drawingInput = document.getElementById('drawingInput')! as HTMLInputElement;
  const addPhotoBtn = document.getElementById('addPhotoBtn')!;
  const addDrawingBtn = document.getElementById('addDrawingBtn')!;

  // Event Listeners
  menuBtn?.addEventListener('click', openSidebar);
  sidebarClose?.addEventListener('click', closeSidebar);
  sidebarOverlay?.addEventListener('click', closeSidebar);

  addPhotoBtn.addEventListener('click', () => photoInput.click());
  addDrawingBtn.addEventListener('click', () => drawingInput.click());

  photoInput.addEventListener('change', (e) => handleFileSelect(e, 'photo'));
  drawingInput.addEventListener('change', (e) => handleFileSelect(e, 'drawing'));

  sendBtn.addEventListener('click', sendMessage);
  messageInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });
  messageInput.addEventListener('input', updateSendButton);

  // Sidebar functions
  function openSidebar() {
    sidebar.classList.add('open');
    sidebarOverlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    sidebar.classList.remove('open');
    sidebarOverlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  // Resizer functionality
  let isResizing = false;
  let startX = 0;
  let startWidth = 0;

  resizer.addEventListener('mousedown', (e) => {
    isResizing = true;
    startX = e.clientX;
    startWidth = sidebar.offsetWidth;
    resizer.classList.add('active');
    document.body.style.cursor = 'col-resize';
    document.body.style.userSelect = 'none';
  });

  document.addEventListener('mousemove', (e) => {
    if (!isResizing) return;
    const diff = e.clientX - startX;
    const newWidth = Math.max(320, Math.min(600, startWidth + diff));
    sidebar.style.width = newWidth + 'px';
  });

  document.addEventListener('mouseup', () => {
    if (isResizing) {
      isResizing = false;
      resizer.classList.remove('active');
      document.body.style.cursor = '';
      document.body.style.userSelect = '';
    }
  });

  // File Handling
  function handleFileSelect(event: Event, type: 'photo' | 'drawing') {
    const input = event.target as HTMLInputElement;
    const file = input.files?.[0];
    if (!file) return;

    if (!file.type.startsWith('image/')) {
      alert('请上传图片文件');
      return;
    }

    // Check if already exists
    if (sources.some(s => s.type === type)) {
      if (!confirm(`已存在${type === 'photo' ? '照片' : '手绘作品'}，是否替换？`)) {
        return;
      }
      sources = sources.filter(s => s.type !== type);
    }

    const reader = new FileReader();
    reader.onload = (e) => {
      const source: Source = {
        id: Date.now().toString(),
        type,
        url: e.target?.result as string,
        name: file.name
      };
      sources.push(source);
      renderSources();

      // Auto start conversation if both sources are present
      if (sources.length === 2 && messages.length === 0) {
        setTimeout(() => {
          startAnalysis();
        }, 500);
      }
    };
    reader.readAsDataURL(file);
    input.value = '';
  }

  function removeSource(id: string) {
    sources = sources.filter(s => s.id !== id);
    renderSources();
  }

  function renderSources() {
    sourceBadge.textContent = `${sources.length}/2`;

    if (sources.length === 0) {
      emptyState.style.display = 'block';
      sourcesList.querySelectorAll('.source-item').forEach(el => el.remove());
      return;
    }

    emptyState.style.display = 'none';
    sourcesList.querySelectorAll('.source-item').forEach(el => el.remove());

    sources.forEach(source => {
      const item = document.createElement('div');
      item.className = 'source-item';
      item.innerHTML = `
        <img src="${source.url}" alt="${source.name}" class="source-preview">
        <div class="source-info">
          <div class="source-label">
            <span>${source.type === 'photo' ? '📷' : '✏️'}</span>
            <span class="source-type-badge">${source.type === 'photo' ? '参考照片' : '手绘作品'}</span>
          </div>
          <button class="remove-source" data-id="${source.id}" aria-label="移除">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      `;
      sourcesList.appendChild(item);
    });

    // Add remove listeners
    sourcesList.querySelectorAll('.remove-source').forEach(btn => {
      btn.addEventListener('click', () => {
        removeSource((btn as HTMLElement).dataset.id!);
      });
    });
  }

  // Chat Functions
  function updateSendButton() {
    sendBtn.disabled = !messageInput.value.trim() || isLoading;
  }

  function updateUIState() {
    if (messages.length === 0) {
      welcomeScreen.style.display = 'flex';
      messagesWrapper.style.display = 'none';
    } else {
      welcomeScreen.style.display = 'none';
      messagesWrapper.style.display = 'flex';
    }
  }

  async function startAnalysis() {
    messages.push({
      role: 'user',
      content: '请分析我的作品，对比参考照片和手绘作品，提供改进建议。'
    });

    updateUIState();
    renderMessages();

    isLoading = true;
    updateSendButton();
    showLoading();

    try {
      const response = await fetch('/api/art-advisor', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          messages,
          sources: sources.map(s => ({ type: s.type, url: s.url }))
        })
      });

      if (!response.ok) {
        let errorMessage = '请求失败';
        try {
          const contentType = response.headers.get('content-type') || '';
          if (contentType.includes('application/json')) {
            const error = await response.json();
            errorMessage = error.message || errorMessage;
          } else {
            const text = await response.text();
            console.error('Non-JSON error response:', text);
            errorMessage = `服务器错误 (${response.status})，请检查开发服务器是否运行`;
          }
        } catch (e) {
          console.error('Error parsing error response:', e);
          errorMessage = `服务器错误 (${response.status})`;
        }
        throw new Error(errorMessage);
      }

      const data = await response.json();
      messages.push({ role: 'ai', content: data.response });
    } catch (error) {
      messages.push({
        role: 'ai',
        content: '抱歉，处理请求时出现了错误。请稍后重试。'
      });
    } finally {
      isLoading = false;
      updateSendButton();
      renderMessages();
    }
  }

  async function sendMessage() {
    const content = messageInput.value.trim();
    if (!content || isLoading) return;

    // First message triggers UI change
    if (messages.length === 0) {
      updateUIState();
    }

    messages.push({ role: 'user', content });
    messageInput.value = '';
    updateSendButton();
    renderMessages();

    isLoading = true;
    updateSendButton();
    showLoading();

    try {
      const response = await fetch('/api/art-advisor', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          messages,
          sources: sources.map(s => ({ type: s.type, url: s.url }))
        })
      });

      if (!response.ok) {
        let errorMessage = '请求失败';
        try {
          const contentType = response.headers.get('content-type') || '';
          if (contentType.includes('application/json')) {
            const error = await response.json();
            errorMessage = error.message || errorMessage;
          } else {
            const text = await response.text();
            console.error('Non-JSON error response:', text);
            errorMessage = `服务器错误 (${response.status})，请检查开发服务器是否运行`;
          }
        } catch (e) {
          console.error('Error parsing error response:', e);
          errorMessage = `服务器错误 (${response.status})`;
        }
        throw new Error(errorMessage);
      }

      const data = await response.json();
      messages.push({ role: 'ai', content: data.response });
    } catch (error) {
      messages.push({
        role: 'ai',
        content: '抱歉，处理请求时出现了错误。请稍后重试。'
      });
    } finally {
      isLoading = false;
      updateSendButton();
      renderMessages();
    }
  }

  function showLoading() {
    const loadingDiv = document.createElement('div');
    loadingDiv.className = 'message ai-message loading-message';
    loadingDiv.id = 'loadingMessage';
    loadingDiv.innerHTML = `
      <div class="message-avatar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 3v18M3 12h18M7.5 7.5l9 9M16.5 7.5l-9 9" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="message-content">
        <div class="message-bubble">
          <div class="loading-spinner">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>
          <span class="loading-text">正在思考...</span>
        </div>
      </div>
    `;
    messagesWrapper.appendChild(loadingDiv);
    messagesWrapper.scrollTop = messagesWrapper.scrollHeight;
  }

  function renderMessages() {
    const loadingMessage = document.getElementById('loadingMessage');
    if (loadingMessage) {
      loadingMessage.remove();
    }

    messagesWrapper.innerHTML = '';

    if (messages.length === 0) {
      updateUIState();
      return;
    }

    messages.forEach((msg, index) => {
      const messageDiv = document.createElement('div');
      messageDiv.className = `message ${msg.role === 'ai' ? 'ai-message' : 'user-message'}`;
      messageDiv.style.animationDelay = `${index * 0.05}s`;
      messageDiv.innerHTML = `
        <div class="message-avatar">
          ${msg.role === 'ai' ? `
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 3v18M3 12h18M7.5 7.5l9 9M16.5 7.5l-9 9" stroke-linecap="round"/>
            </svg>
          ` : `
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          `}
        </div>
        <div class="message-content">
          <div class="message-bubble">
            ${formatMessageContent(msg.content)}
          </div>
        </div>
      `;
      messagesWrapper.appendChild(messageDiv);
    });

    messagesWrapper.scrollTop = messagesWrapper.scrollHeight;
  }

  function formatMessageContent(content: string): string {
    return content
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/^- (.+)$/gm, '<li>$1</li>')
      .replace(/<li>(.+?)<\/li>/g, '<ul><li>$1</li></ul>')
      .replace(/<\/ul>\s*<ul>/g, '')
      .replace(/\n/g, '<br>');
  }

  // Initialize
  updateUIState();
  renderSources();
</script>
