---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';
import probe from 'probe-image-size';

// contentRoot: 公众号同步过来的文章都在这里
const contentRoot = path.resolve(process.cwd(), 'public/content/group');

// 判断是否可能是二维码/图标：接近正方形且体积不大
function isLikelyQrCodeOrIcon(filePath: string, size: number): boolean {
  try {
    const fd = fs.openSync(filePath, 'r');
    const result = probe.sync(fs.readFileSync(filePath));
    fs.closeSync(fd);

    if (!result) return false;

    const ratio = Math.max(result.width, result.height) / Math.min(result.width, result.height);
    // 宽高比接近 1（正方形）且文件小于 200KB → 很可能是二维码/logo/图标
    if (ratio >= 0.9 && ratio <= 1.1 && size < 200 * 1024) {
      return true;
    }
    return false;
  } catch (e) {
    // 如果读取失败，不过滤
    return false;
  }
}

// 收集所有文章
interface ArticleInfo {
  groupName: string;
  articleDir: string;
  fullPath: string;
  slug: string;
  title: string;
  coverImage: string | null;
  dateStamp: number;
}

const allArticles: ArticleInfo[] = [];

// 递归遍历所有分组，找到所有文章目录
if (fs.existsSync(contentRoot)) {
  const groupNames = fs.readdirSync(contentRoot).filter(f =>
    fs.statSync(path.join(contentRoot, f)).isDirectory()
  );

  groupNames.forEach(groupName => {
    const groupPath = path.join(contentRoot, groupName);
    const articleDirs = fs.readdirSync(groupPath).filter(articleDir =>
      fs.statSync(path.join(groupPath, articleDir)).isDirectory()
    );

    articleDirs.forEach(articleDir => {
      const articleFullPath = path.join(groupPath, articleDir);

      // 找 title 文件
      const titlePath = path.join(articleFullPath, 'title.txt');
      let title = articleDir;
      if (fs.existsSync(titlePath)) {
        title = fs.readFileSync(titlePath, 'utf-8').trim();
      }

      // 找封面图片：选择体积最大且不是二维码的图片
      let coverImage: string | null = null;

      // 先找 assets 目录
      const assetsDir = path.join(articleFullPath, 'assets');
      if (fs.existsSync(assetsDir)) {
        let images = fs.readdirSync(assetsDir)
          .filter(f => /\.(jpg|jpeg|png|gif|webp)$/i.test(f))
          // 过滤掉二维码、emoji、表情包（按文件名）
          .filter(f => {
            const lower = f.toLowerCase();
            if (lower.includes('qrcode') || lower.includes('二维码') ||
                lower.includes('emoji') || lower.includes('表情') ||
                lower.includes('icon') || lower.includes('logo') ||
                lower.includes('关注') || lower.includes('公众号') ||
                lower.includes('欢迎') || lower.includes('结尾') ||
                lower.includes('footer')) {
              return false;
            }
            return true;
          })
          // 按文件大小降序排序，取最大的一张（质量最好）
          .map(f => {
            const filePath = path.join(assetsDir, f);
            const stat = fs.statSync(filePath);
            return { file: f, size: stat.size, path: filePath };
          })
          .sort((a, b) => b.size - a.size)
          // 智能过滤：去掉接近正方形的小图（很可能是二维码）
          .filter(img => !isLikelyQrCodeOrIcon(img.path, img.size));

        // 找到第一张符合条件的图片
        if (images.length > 0) {
          coverImage = `/content/group/${encodeURIComponent(groupName)}/${encodeURIComponent(articleDir)}/assets/${images[0].file}`;
        }
      }

      // 如果 assets 目录没找到，直接在文章目录找
      if (!coverImage) {
        let images = fs.readdirSync(articleFullPath)
          .filter(f => /\.(jpg|jpeg|png|gif|webp)$/i.test(f))
          // 过滤掉二维码、emoji、表情包（按文件名）
          .filter(f => {
            const lower = f.toLowerCase();
            if (lower.includes('qrcode') || lower.includes('二维码') ||
                lower.includes('emoji') || lower.includes('表情') ||
                lower.includes('icon') || lower.includes('logo') ||
                lower.includes('关注') || lower.includes('公众号') ||
                lower.includes('欢迎') || lower.includes('结尾') ||
                lower.includes('footer')) {
              return false;
            }
            return true;
          })
          // 按文件大小降序排序，取最大的一张
          .map(f => {
            const filePath = path.join(articleFullPath, f);
            const stat = fs.statSync(filePath);
            return { file: f, size: stat.size, path: filePath };
          })
          .sort((a, b) => b.size - a.size)
          // 智能过滤：去掉接近正方形的小图（很可能是二维码）
          .filter(img => !isLikelyQrCodeOrIcon(img.path, img.size));

        if (images.length > 0) {
          coverImage = `/content/group/${encodeURIComponent(groupName)}/${encodeURIComponent(articleDir)}/${images[0].file}`;
        }
      }

      // 从文章目录名提取日期 (格式: YYYY-MM-DD 标题)
      let dateStamp: number;
      const dateMatch = articleDir.match(/^(\d{4})-(\d{2})-(\d{2})\s/);
      if (dateMatch) {
        // 有日期前缀，使用该日期排序
        const [year, month, day] = dateMatch.slice(1).map(Number);
        dateStamp = new Date(year, month - 1, day).getTime();
      } else {
        // 没有日期前缀，使用文件修改时间
        const stat = fs.statSync(articleFullPath);
        dateStamp = stat.mtimeMs;
      }

      // slug: 文章链接格式 /posts/group-article-slug
      // 实际链接是由微信同步脚本生成的 markdown 在 src/content/posts/
      // 我们这里用 groupName + articleDir 作为 slug
      const slug = `${groupName}-${articleDir}`.replace(/\s+/g, '-');

      allArticles.push({
        groupName,
        articleDir,
        fullPath: articleFullPath,
        slug,
        title,
        coverImage,
        dateStamp,
      });
    });
  });
}

// 按日期倒序排序（最新的在前）
allArticles.sort((a, b) => b.dateStamp - a.dateStamp);

// 只取最近 30 篇
const recentArticles = allArticles.slice(0, 30);

const basePath = import.meta.env.BASE_URL;
---

<BaseLayout title="全部文章 · 李春晓">
  <main style="max-width:760px; margin:0 auto; padding:8rem 2rem 5rem;">
    <div style="margin-bottom:3rem;">
      <div style="display:flex; gap:1rem; margin-bottom:0.5rem;">
        <a
          href={`${basePath.endsWith('/') ? basePath : `${basePath}/`}posts`}
          style="font-family:'Caveat',cursive; font-size:1.2rem; color:var(--sage); text-decoration:none; transition:color 0.2s;"
          onmouseover="this.style.color='#c96a3e'"
          onmouseout="this.style.color='var(--sage)'"
        >
          // 全部文章
        </a>
        <a
          href={`${basePath.endsWith('/') ? basePath : `${basePath}/`}groups`}
          style="font-family:'Caveat',cursive; font-size:1.2rem; color:var(--text-muted); text-decoration:none; transition:color 0.2s;"
          onmouseover="this.style.color='#c96a3e'"
          onmouseout="this.style.color='var(--text-muted)'"
        >
          · 分类浏览
        </a>
      </div>
      <h1 style="font-family:'Noto Serif SC',serif; font-size:2.5rem; font-weight:700; color:var(--brown); margin-bottom:1rem;">全部文章</h1>
      <div style="width:60px; height:3px; background:linear-gradient(to right,#f4a97f,#c96a3e); border-radius:2px;"></div>
      {allArticles.length > 0 && (
        <p style="margin-top:1rem; color:var(--text-muted); font-size:0.9rem;">
          展示最近 {recentArticles.length} 篇推送，按时间从新到旧排列
        </p>
      )}
    </div>

    {recentArticles.length === 0 ? (
      <div style="text-align:center; padding:4rem; color:var(--text-muted); font-family:'Noto Serif SC',serif;">
        <div style="font-size:3rem; margin-bottom:1rem;">📝</div>
        <p>还没有文章，等待公众号推送同步...</p>
      </div>
    ) : (
      <div id="masonry-container" style="position: relative;">
        {recentArticles.map(article => {
          const link = `${basePath.endsWith('/') ? basePath : `${basePath}/`}posts/${article.slug}`;
          return (
          <a
            href={link}
            style="display:block; width:calc((100% - 2 * 1.5rem) / 3); text-decoration:none; background:var(--warm-white); border-radius:16px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,.06); transition:transform 0.25s,box-shadow 0.25s; margin-bottom: 1.5rem;"
            onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 30px rgba(0,0,0,.1)'"
            onmouseout="this.style.transform='';this.style.boxShadow='0 2px 12px rgba(0,0,0,.06)'"
          >
            {article.coverImage && (
              <div style="width:100%; line-height: 0; overflow:hidden; background:var(--bg-secondary);">
                <img
                  src={article.coverImage}
                  alt={article.title}
                  style="width:100%; height:auto; display:block;"
                />
              </div>
            )}
            <div style={`padding:${article.coverImage ? '1rem 1rem 1.2rem' : '1.5rem 1rem 1.5rem'};`}>
              <div style="font-family:'Noto Serif SC',serif; font-size:1.15rem; font-weight:700; color:#5c3d2e; margin-bottom:0.5rem; line-height:1.4;">
                {article.title}
              </div>
              <div style="font-size:0.85rem; color:#7a9e7e; display:flex; align-items:center; gap:0.5rem;">
                <span>{article.groupName}</span>
              </div>
            </div>
          </a>
          );
        })}
      </div>
    )}
  </main>
</BaseLayout>

<script>
  // 原生 Masonry 算法实现真正的错落瀑布流
  // 每个卡片放到当前高度最小的列 → 真正错落，短卡片下方不留空白
  (function() {
    function getColumnCount() {
      const width = window.innerWidth;
      if (width >= 768) {
        return 3; // 桌面：3列
      } else if (width >= 480) {
        return 2; // 平板：2列
      } else {
        return 1; // 手机：1列
      }
    }

    function initMasonry() {
      const container = document.getElementById('masonry-container');
      if (!container) return;

      const items = Array.from(container.children);
      const columnCount = getColumnCount();
      const gap = 24; // 1.5rem = 24px

      // 计算每列宽度
      const containerWidth = container.clientWidth;
      const columnWidth = (containerWidth - (columnCount - 1) * gap) / columnCount;

      // 初始化每列高度
      const columnHeights = new Array(columnCount).fill(0);

      items.forEach((item, index) => {
        item.style.width = columnWidth + 'px';
        item.style.position = 'absolute';

        // 找到当前高度最小的列
        const minHeight = Math.min(...columnHeights);
        const columnIndex = columnHeights.indexOf(minHeight);

        // 设置位置
        const left = columnIndex * (columnWidth + gap);
        const top = minHeight;

        item.style.left = left + 'px';
        item.style.top = top + 'px';

        // 更新列高度
        columnHeights[columnIndex] += item.offsetHeight + gap;
      });

      // 设置容器高度
      container.style.height = Math.max(...columnHeights) + 'px';
    }

    // 图片加载完成后再布局
    window.addEventListener('load', () => {
      setTimeout(initMasonry, 100);
    });

    // 窗口 resize 重新布局
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(initMasonry, 200);
    });

    // 屏幕旋转时重新布局（手机）
    window.addEventListener('orientationchange', () => {
      setTimeout(initMasonry, 200);
    });
  })();
</script>

<style>
  :root {
    --cream:#fdf6ec;--warm-white:#fffaf4;--peach:#f4a97f;
    --terracotta:#c96a3e;--sage:#7a9e7e;--sand:#e8d5b7;
    --brown:#5c3d2e;--text-main:#3a2518;--text-muted:#7a5c47;
  }
</style>
