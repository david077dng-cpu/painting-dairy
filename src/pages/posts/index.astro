---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';
import probe from 'probe-image-size';
import matter from 'gray-matter';

// contentRoot: 公众号同步过来的文章都在这里
const contentRoot = path.resolve(process.cwd(), 'public/content/group');

// 判断是否可能是二维码/图标：接近正方形且体积不大
function isLikelyQrCodeOrIcon(filePath: string, size: number): boolean {
  try {
    const fd = fs.openSync(filePath, 'r');
    const result = probe.sync(fs.readFileSync(filePath));
    fs.closeSync(fd);

    if (!result) return false;

    const ratio = Math.max(result.width, result.height) / Math.min(result.width, result.height);
    // 宽高比接近 1（正方形）且文件小于 200KB → 很可能是二维码/logo/图标
    if (ratio >= 0.9 && ratio <= 1.1 && size < 200 * 1024) {
      return true;
    }
    return false;
  } catch (e) {
    // 如果读取失败，不过滤
    return false;
  }
}

// 收集所有文章
interface ArticleInfo {
  groupName: string;
  articleDir: string;
  fullPath: string;
  slug: string;
  title: string;
  coverImage: string | null;
  dateStamp: number;
}

const allArticles: ArticleInfo[] = [];

// 递归遍历所有分组，找到所有文章目录
if (fs.existsSync(contentRoot)) {
  const groupNames = fs.readdirSync(contentRoot).filter(f =>
    fs.statSync(path.join(contentRoot, f)).isDirectory()
  );

  groupNames.forEach(groupName => {
    const groupPath = path.join(contentRoot, groupName);
    const articleDirs = fs.readdirSync(groupPath).filter(articleDir =>
      fs.statSync(path.join(groupPath, articleDir)).isDirectory()
    );

    articleDirs.forEach(articleDir => {
      const articleFullPath = path.join(groupPath, articleDir);

      // 找 title 文件
      const titlePath = path.join(articleFullPath, 'title.txt');
      let title = articleDir;
      if (fs.existsSync(titlePath)) {
        title = fs.readFileSync(titlePath, 'utf-8').trim();
      }

      // 找封面图片：选择体积最大且不是二维码的图片
      let coverImage: string | null = null;

      // 先找 assets 目录
      const assetsDir = path.join(articleFullPath, 'assets');
      if (fs.existsSync(assetsDir)) {
        let images = fs.readdirSync(assetsDir)
          .filter(f => /\.(jpg|jpeg|png|gif|webp)$/i.test(f))
          // 过滤掉二维码、emoji、表情包（按文件名）
          .filter(f => {
            const lower = f.toLowerCase();
            if (lower.includes('qrcode') || lower.includes('二维码') ||
                lower.includes('emoji') || lower.includes('表情') ||
                lower.includes('icon') || lower.includes('logo') ||
                lower.includes('关注') || lower.includes('公众号') ||
                lower.includes('欢迎') || lower.includes('结尾') ||
                lower.includes('footer')) {
              return false;
            }
            return true;
          })
          // 按文件大小降序排序，取最大的一张（质量最好）
          .map(f => {
            const filePath = path.join(assetsDir, f);
            const stat = fs.statSync(filePath);
            return { file: f, size: stat.size, path: filePath };
          })
          .sort((a, b) => b.size - a.size)
          // 智能过滤：去掉接近正方形的小图（很可能是二维码）
          .filter(img => !isLikelyQrCodeOrIcon(img.path, img.size));

        // 找到第一张符合条件的图片
        if (images.length > 0) {
          coverImage = `/content/group/${encodeURIComponent(groupName)}/${encodeURIComponent(articleDir)}/assets/${images[0].file}`;
        }
      }

      // 如果 assets 目录没找到，直接在文章目录找
      if (!coverImage) {
        let images = fs.readdirSync(articleFullPath)
          .filter(f => /\.(jpg|jpeg|png|gif|webp)$/i.test(f))
          // 过滤掉二维码、emoji、表情包（按文件名）
          .filter(f => {
            const lower = f.toLowerCase();
            if (lower.includes('qrcode') || lower.includes('二维码') ||
                lower.includes('emoji') || lower.includes('表情') ||
                lower.includes('icon') || lower.includes('logo') ||
                lower.includes('关注') || lower.includes('公众号') ||
                lower.includes('欢迎') || lower.includes('结尾') ||
                lower.includes('footer')) {
              return false;
            }
            return true;
          })
          // 按文件大小降序排序，取最大的一张
          .map(f => {
            const filePath = path.join(articleFullPath, f);
            const stat = fs.statSync(filePath);
            return { file: f, size: stat.size, path: filePath };
          })
          .sort((a, b) => b.size - a.size)
          // 智能过滤：去掉接近正方形的小图（很可能是二维码）
          .filter(img => !isLikelyQrCodeOrIcon(img.path, img.size));

        if (images.length > 0) {
          coverImage = `/content/group/${encodeURIComponent(groupName)}/${encodeURIComponent(articleDir)}/${images[0].file}`;
        }
      }

      // 从文章目录名提取日期 (格式: YYYY-MM-DD 标题)
      let dateStamp: number;
      const dateMatch = articleDir.match(/^(\d{4})-(\d{2})-(\d{2})\s/);
      if (dateMatch) {
        // 有日期前缀，使用该日期排序
        const [year, month, day] = dateMatch.slice(1).map(Number);
        dateStamp = new Date(year, month - 1, day).getTime();
      } else {
        // 没有日期前缀，使用文件修改时间
        const stat = fs.statSync(articleFullPath);
        dateStamp = stat.mtimeMs;
      }

      // slug: 文章链接格式 /posts/group-article-slug
      // 实际链接是由微信同步脚本生成的 markdown 在 src/content/posts/
      // 我们这里用 groupName + articleDir 作为 slug
      const slug = `${groupName}-${articleDir}`.replace(/\s+/g, '-');

      allArticles.push({
        groupName,
        articleDir,
        fullPath: articleFullPath,
        slug,
        title,
        coverImage,
        dateStamp,
      });
    });
  });
}

// Add standalone markdown posts from src/content/posts/
const postsRoot = path.resolve(process.cwd(), 'src/content/posts');
if (fs.existsSync(postsRoot)) {
  const mdFiles = fs.readdirSync(postsRoot).filter(f => f.endsWith('.md'));
  mdFiles.forEach(file => {
    const slug = file.replace(/\.md$/, '');
    const fullPath = path.join(postsRoot, file);
    const fileContent = fs.readFileSync(fullPath, 'utf-8');
    const { data: frontmatter, content } = matter(fileContent);

    let title = frontmatter.title || slug;
    let dateStamp;
    let coverImage = null;

    if (frontmatter.date) {
      const date = new Date(frontmatter.date);
      dateStamp = date.getTime();
    } else {
      const stat = fs.statSync(fullPath);
      dateStamp = stat.mtimeMs;
    }

    // Find first image in content for cover
    const coverMatch = content.match(/!\[.*?\]\((\/.*?\.(jpg|jpeg|png|gif|webp))/i);
    if (coverMatch) {
      coverImage = coverMatch[1];
    }

    allArticles.push({
      groupName: 'Painting Diary',
      articleDir: file,
      fullPath,
      slug,
      title,
      coverImage,
      dateStamp,
    });
  });
}

// 按日期倒序排序（最新的在前）
allArticles.sort((a, b) => b.dateStamp - a.dateStamp);

// 只取最近 30 篇
const recentArticles = allArticles.slice(0, 30);

const basePath = import.meta.env.BASE_URL;
const normalizedBasePath = basePath.endsWith('/') ? basePath : basePath + '/';
const loadMoreBtnDisplay = recentArticles.length >= allArticles.length ? 'none' : 'block';
// 序列化所有文章数据给客户端（用于Show Me More加载
const allArticlesJson = JSON.stringify(allArticles.map(a => ({
  slug: a.slug,
  title: a.title,
  coverImage: a.coverImage,
  groupName: a.groupName
})));
const initialCount = recentArticles.length;
---

<BaseLayout title="全部文章 · 李春晓">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
  </head>
  <main class="posts-page">
    <div class="container">
      <header class="page-header">
        <div class="breadcrumb">
          <span class="breadcrumb-item active">全部文章</span>
          <a href={`${normalizedBasePath}groups`} class="breadcrumb-item">分类浏览</a>
        </div>
        <h1 class="page-title">全部文章</h1>
        <div class="title-accent"></div>
        {allArticles.length > 0 && (
          <p class="page-description">
            展示最近 {recentArticles.length} 篇随笔，按时间从新到旧排列
          </p>
        )}
      </header>

      {recentArticles.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">🎨</div>
          <p>还没有文章，静待花开...</p>
        </div>
      ) : (
        <div id="masonry-container" class="masonry-container" data-all-articles={allArticlesJson} data-base-path={normalizedBasePath} data-initial-count={initialCount}>
          {recentArticles.map((article, index) => {
            const link = `${normalizedBasePath}posts/${article.slug}`;
            const contentClass = article.coverImage ? 'article-content has-image' : 'article-content';
            return (
              <a
                href={link}
                class="article-card"
              >
                {article.coverImage && (
                  <div class="article-image-wrapper">
                    <img
                      src={article.coverImage}
                      alt={article.title}
                      class="article-image"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class={contentClass}>
                  <h2 class="article-title">{article.title}</h2>
                  <div class="article-group">
                    <span>{article.groupName}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      )}

      <div class="load-more-wrapper">
        <button id="loadMoreBtn" class="load-more-btn" style={{"display": loadMoreBtnDisplay}}>
          加载更多文章
        </button>
      </div>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  // JavaScript 瀑布流 - 先行后列顺序，保持错落效果
  (function() {
    const container = document.getElementById('masonry-container');
    if (!container) return;

    const allArticles = JSON.parse(container.dataset.allArticles);
    const normalizedBasePath = container.dataset.basePath;
    const initialCount = parseInt(container.dataset.initialCount, 10);
    let currentCount = initialCount;
    const batchSize = 30;
    const gap = 16; // 卡片间距

    function getColumnCount() {
      const width = window.innerWidth;
      if (width >= 1200) {
        return 4; // 大屏：4列
      } else if (width >= 768) {
        return 3; // 平板：3列
      } else if (width > 640) {
        return 2; // 小屏：2列
      } else {
        return 1; // 手机：1列
      }
    }

    function createArticleElement(article) {
      const link = `${normalizedBasePath}posts/${article.slug}`;
      const a = document.createElement('a');
      a.href = link;
      a.className = 'article-card';

      if (article.coverImage) {
        const imgDiv = document.createElement('div');
        imgDiv.className = 'article-image-wrapper';
        const img = document.createElement('img');
        img.src = article.coverImage;
        img.alt = article.title;
        img.className = 'article-image';
        img.loading = 'lazy';
        imgDiv.appendChild(img);
        a.appendChild(imgDiv);
      }

      const contentDiv = document.createElement('div');
      contentDiv.className = 'article-content';
      if (article.coverImage) contentDiv.classList.add('has-image');

      const titleDiv = document.createElement('h2');
      titleDiv.className = 'article-title';
      titleDiv.textContent = article.title;

      const groupDiv = document.createElement('div');
      groupDiv.className = 'article-group';
      const span = document.createElement('span');
      span.textContent = article.groupName;
      groupDiv.appendChild(span);

      contentDiv.appendChild(titleDiv);
      contentDiv.appendChild(groupDiv);
      a.appendChild(contentDiv);

      return a;
    }

    function initMasonry() {
      const items = Array.from(container.children);
      const columnCount = getColumnCount();

      // 计算每列宽度
      const containerWidth = container.clientWidth;
      const columnWidth = (containerWidth - (columnCount - 1) * gap) / columnCount;

      // 初始化每列高度
      const columnHeights = new Array(columnCount).fill(0);

      // 保持卡片原有顺序，依次放到当前高度最小的列中
      // 这样自动平衡高度：高列自然少放卡片，矮列多放，整体更均匀
      // 如果某一列因为长帖子变高了，后续卡片自动去更矮的列，正好满足需求
      items.forEach((item) => {
        item.style.width = columnWidth + 'px';
        item.style.position = 'absolute';

        // 找到当前高度最小的列，把卡片放进去
        const minHeight = Math.min(...columnHeights);
        const columnIndex = columnHeights.indexOf(minHeight);
        const top = minHeight;
        const left = columnIndex * (columnWidth + gap);

        item.style.left = left + 'px';
        item.style.top = top + 'px';

        // 更新列高度
        columnHeights[columnIndex] += item.offsetHeight + gap;
      });

      // 设置容器高度
      container.style.height = Math.max(...columnHeights) + 'px';
    }

    function loadMore() {
      const nextArticles = allArticles.slice(currentCount, currentCount + batchSize);
      if (nextArticles.length === 0) {
        document.getElementById('loadMoreBtn').style.display = 'none';
        return;
      }

      nextArticles.forEach(article => {
        const el = createArticleElement(article);
        container.appendChild(el);
        currentCount++;
      });

      // 加载完重新布局
      setTimeout(initMasonry, 50);

      if (currentCount >= allArticles.length) {
        document.getElementById('loadMoreBtn').style.display = 'none';
      }
    }

    // DOM 就绪后立即布局，让用户尽快看到内容
    // 所有图片加载完成后再重新布局一次校正位置
    function runInitMasonry() {
      setTimeout(initMasonry, 0);
    }

    if (document.readyState === 'complete') {
      runInitMasonry();
    } else if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', runInitMasonry);
      window.addEventListener('load', () => setTimeout(initMasonry, 100));
    } else {
      runInitMasonry();
      window.addEventListener('load', () => setTimeout(initMasonry, 100));
    }

    // 窗口 resize 重新布局
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(initMasonry, 200);
    });

    // 屏幕旋转时重新布局（手机）
    window.addEventListener('orientationchange', () => {
      setTimeout(initMasonry, 200);
    });

    // 加载更多按钮
    document.getElementById('loadMoreBtn').addEventListener('click', loadMore);
  })();
</script>

<style is:global>
  .posts-page {
    min-height: calc(100vh - 80px);
    background: var(--bg-primary, #ffffff);
    padding: 6rem 0 4rem;
    position: relative;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .page-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .breadcrumb {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
    font-family: 'Caveat', cursive;
    font-size: 1.4rem;
  }

  .breadcrumb-item {
    color: var(--text-secondary, #787774);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .breadcrumb-item:hover {
    color: var(--accent, #2eaadc);
  }

  .breadcrumb-item.active {
    color: var(--accent, #2eaadc);
  }

  .page-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--text-primary, #37352f);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .title-accent {
    width: 80px;
    height: 4px;
    background: linear-gradient(90deg, var(--accent, #2eaadc), var(--accent-hover, #1a9cd0));
    border-radius: 2px;
    margin: 0 auto 1.5rem;
  }

  .page-description {
    color: var(--text-secondary, #787774);
    font-size: 1rem;
  }

  .empty-state {
    text-align: center;
    padding: 6rem 2rem;
    color: var(--text-secondary, #787774);
    font-family: 'Noto Serif SC', serif;
  }

  .empty-icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
  }

  /* 瀑布流布局 - 先行后列，卡片自适应高度 */
  .masonry-container {
    position: relative;
    min-height: 400px;
    margin-bottom: 4rem;
  }

  .article-card {
    display: block;
    text-decoration: none;
    background: var(--bg-primary, #ffffff);
    border: none;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
    opacity: 1;
  }

  .article-card:hover {
    transform: translate(0, -4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
  }

  .article-image-wrapper {
    width: 100%;
    line-height: 0;
    overflow: hidden;
    background: var(--bg-secondary, #f7f6f3);
    position: relative;
  }

  .article-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.4s ease;
  }

  .article-card:hover .article-image {
    transform: scale(1.03);
  }

  /* Rednote-style: clean content */
  .article-content {
    padding: 0.8rem 0.8rem 1rem;
  }

  .article-content.has-image {
    padding: 0.7rem 0.8rem 0.9rem;
  }

  .article-title {
    font-family: 'Inter', 'Noto Sans SC', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary, #37352f);
    line-height: 1.4;
    margin-bottom: 0.4rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-group {
    font-size: 0.75rem;
    color: var(--text-tertiary, #9b9a97);
    display: flex;
    align-items: center;
    font-family: 'Inter', 'Noto Sans SC', sans-serif;
  }

  .load-more-wrapper {
    text-align: center;
  }

  .load-more-btn {
    padding: 0.9rem 2.2rem;
    background: var(--accent, #2eaadc);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-family: 'Inter', 'Noto Sans SC', sans-serif;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 12px rgba(46, 170, 220, 0.2);
  }

  .load-more-btn:hover {
    background: var(--accent-hover, #1a9cd0);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(46, 170, 220, 0.28);
  }

  .load-more-btn:active {
    transform: translateY(0);
  }

  /* Responsive: adjust columns for different screen sizes */
  @media (max-width: 1024px) {
    .page-title {
      font-size: 2.5rem;
    }

    .page-header {
      margin-bottom: 3rem;
    }
  }

  @media (max-width: 640px) {
    .posts-page {
      padding: 5rem 0 3rem;
    }

    .page-title {
      font-size: 2rem;
    }

    .breadcrumb {
      font-size: 1.2rem;
    }

    .container {
      padding: 0 1rem;
    }

    .article-title {
      font-size: 0.95rem;
    }
  }
</style>
