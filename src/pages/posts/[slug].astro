---
import PostLayout from '../../layouts/PostLayout.astro';
import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';
import { marked } from 'marked';

const { slug } = Astro.params;
const postsDir = path.resolve(process.cwd(), 'src/content/posts');

// 查找匹配的文章
const files = fs.readdirSync(postsDir).filter(file => file.endsWith('.md'));
let matchedFile: string | null = null;

for (const file of files) {
  const fileSlug = file.replace(/\.md$/, '');
  if (fileSlug === slug || fileSlug.toLowerCase() === slug?.toLowerCase()) {
    matchedFile = file;
    break;
  }
}

if (!matchedFile) {
  return Astro.redirect('/404');
}

// 读取文章内容
const filePath = path.join(postsDir, matchedFile);
let fileContent = fs.readFileSync(filePath, 'utf-8');

// 解析 frontmatter，gray-matter 处理
let { data, content } = matter(fileContent);

// 如果 gray-matter 没有剥离成功（content 仍然包含 --- 开头），手动剥离
if (content.startsWith('---')) {
  const lines = fileContent.split('\n');
  let inFrontmatter = false;
  const contentLines = [];
  let foundStart = false;
  let foundEnd = false;

  for (const line of lines) {
    if (!foundStart && line.trim() === '---') {
      foundStart = true;
      inFrontmatter = true;
      continue;
    }
    if (inFrontmatter && line.trim() === '---') {
      inFrontmatter = false;
      foundEnd = true;
      continue;
    }
    if (!inFrontmatter) {
      contentLines.push(line);
    }
  }

  if (foundStart && foundEnd) {
    content = contentLines.join('\n');
  }
}

// 格式化日期为 YYYY-MM-DD
let formattedDate: string;
if (data.date instanceof Date) {
  formattedDate = data.date.toISOString().split('T')[0];
} else if (typeof data.date === 'string' && data.date) {
  formattedDate = data.date;
} else if (typeof data.date === 'number') {
  formattedDate = new Date(data.date).toISOString().split('T')[0];
} else {
  // Fallback: use file modification time if date is missing/invalid
  const stat = fs.statSync(filePath);
  formattedDate = new Date(stat.mtime).toISOString().split('T')[0];
}

// 渲染 markdown 为 HTML
const htmlContent = marked.parse(content);

// 更新 data 中的日期为格式化后的
const frontmatter = {
  ...data,
  date: formattedDate,
};

// 如果 markdown 内容已经以一级标题开头，说明文章自带标题，不需要 PostLayout 额外显示 header
// 这样和微信原始文章布局保持一致
const trimmedContent = content.trimStart();
const hasOwnTitle = trimmedContent.startsWith('# ') || trimmedContent.startsWith('## ');
const showHeader = !hasOwnTitle;
---

<PostLayout frontmatter={frontmatter} showHeader={showHeader}>
  <div set:html={htmlContent}></div>
</PostLayout>
