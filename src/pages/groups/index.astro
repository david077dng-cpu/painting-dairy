---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';
import probe from 'probe-image-size';

// PM2 启动时 cwd 就是项目根目录 /var/www/html
const contentRoot = path.resolve(process.cwd(), 'public/content/group');

// 获取所有 group 目录
const groupNames = fs.existsSync(contentRoot)
  ? fs.readdirSync(contentRoot).filter(f => fs.statSync(path.join(contentRoot, f)).isDirectory())
  : [];

// 合集中文名称映射
const groupNamesMap: Record<string, string> = {
  'Q版漫画': 'Q版漫画',
  '写生': '写生',
  '北京': '北京',
  '天津': '天津',
  '展览': '展览',
  '板绘': '板绘',
  '水彩': '水彩',
  '水彩游记': '水彩游记',
  '照片变水彩': '照片变水彩',
  '电影': '电影',
  '胡同': '胡同',
  '读书笔记': '读书笔记',
};

// 判断是否可能是二维码/图标：接近正方形且体积不大
function isLikelyQrCodeOrIcon(filePath: string, size: number): boolean {
  try {
    const fd = fs.openSync(filePath, 'r');
    const result = probe.sync(fs.readFileSync(filePath));
    fs.closeSync(fd);

    if (!result) return false;

    const ratio = Math.max(result.width, result.height) / Math.min(result.width, result.height);
    // 宽高比接近 1（正方形）且文件小于 200KB → 很可能是二维码/logo/图标
    if (ratio >= 0.9 && ratio <= 1.1 && size < 200 * 1024) {
      return true;
    }
    return false;
  } catch (e) {
    // 如果读取失败，不过滤
    return false;
  }
}

// 统计每个组的文章数量，并获取封面图片（取最新文章的第一张图）
const groupStats = groupNames.reduce((acc, name) => {
  const groupPath = path.join(contentRoot, name);
  let items = fs.readdirSync(groupPath).filter(f =>
    fs.statSync(path.join(groupPath, f)).isDirectory()
  );
  // 按名称倒序，最新的在前
  items = items.sort((a, b) => b.localeCompare(a));

  let coverImage = null;
  if (items.length > 0) {
    const latestItem = items[0];
    const itemDir = path.join(groupPath, latestItem);
    const assetsDir = path.join(itemDir, 'assets');

    // 先找 assets 目录
    if (fs.existsSync(assetsDir)) {
      let images = fs.readdirSync(assetsDir)
        .filter(f => /\.(jpg|jpeg|png|gif|webp)$/i.test(f))
        // 过滤掉二维码、emoji、表情包（按文件名）
        .filter(f => {
          const lower = f.toLowerCase();
          // 排除二维码、emoji、表情、图标、logo、文末关注图
          if (lower.includes('qrcode') || lower.includes('二维码') ||
              lower.includes('emoji') || lower.includes('表情') ||
              lower.includes('icon') || lower.includes('logo') ||
              lower.includes('关注') || lower.includes('公众号') ||
              lower.includes('欢迎') || lower.includes('结尾') ||
              lower.includes('footer')) {
            return false;
          }
          return true;
        })
        // 按文件大小降序排序，取最大的一张（质量最好）
        .map(f => {
          const filePath = path.join(assetsDir, f);
          const stat = fs.statSync(filePath);
          return { file: f, size: stat.size, path: filePath };
        })
        .sort((a, b) => b.size - a.size)
        // 智能过滤：去掉接近正方形的小图（很可能是二维码）
        .filter(img => !isLikelyQrCodeOrIcon(img.path, img.size));

      // 找到第一张符合条件的图片
      if (images.length > 0) {
        coverImage = `/content/group/${encodeURIComponent(name)}/${encodeURIComponent(latestItem)}/assets/${images[0].file}`;
      }
    }
    // 再找同级目录
    if (!coverImage) {
      let images = fs.readdirSync(itemDir)
        .filter(f => /\.(jpg|jpeg|png|gif|webp)$/i.test(f))
        // 过滤掉二维码、emoji、表情包（按文件名）
        .filter(f => {
          const lower = f.toLowerCase();
          if (lower.includes('qrcode') || lower.includes('二维码') ||
              lower.includes('emoji') || lower.includes('表情') ||
              lower.includes('icon') || lower.includes('logo') ||
              lower.includes('关注') || lower.includes('公众号') ||
              lower.includes('欢迎') || lower.includes('结尾') ||
              lower.includes('footer')) {
            return false;
          }
          return true;
        })
        // 按文件大小降序排序，取最大的一张
        .map(f => {
          const filePath = path.join(itemDir, f);
          const stat = fs.statSync(filePath);
          return { file: f, size: stat.size, path: filePath };
        })
        .sort((a, b) => b.size - a.size)
        // 智能过滤：去掉接近正方形的小图（很可能是二维码）
        .filter(img => !isLikelyQrCodeOrIcon(img.path, img.size));

      if (images.length > 0) {
        coverImage = `/content/group/${encodeURIComponent(name)}/${encodeURIComponent(latestItem)}/${images[0].file}`;
      }
    }
  }

  acc[name] = { count: items.length, coverImage };
  return acc;
}, {} as Record<string, { count: number, coverImage: string | null }>);

const basePath = import.meta.env.BASE_URL;
---

<BaseLayout title="合集 · 李春晓">
  <main style="max-width:1200px; margin:0 auto; padding:8rem 2rem 5rem;">
    <div style="margin-bottom:3rem;">
      <div style="display:flex; gap:1rem; margin-bottom:0.5rem;">
        <a
          href={`${basePath.endsWith('/') ? basePath : `${basePath}/`}posts`}
          style="font-family:'Caveat',cursive; font-size:1.2rem; color:var(--text-muted); text-decoration:none; transition:color 0.2s;"
          onmouseover="this.style.color='#c96a3e'"
          onmouseout="this.style.color='var(--text-muted)'"
        >
          // 我的写作
        </a>
        <a
          href={`${basePath.endsWith('/') ? basePath : `${basePath}/`}groups`}
          style="font-family:'Caveat',cursive; font-size:1.2rem; color:var(--sage); text-decoration:none; transition:color 0.2s;"
          onmouseover="this.style.color='#c96a3e'"
          onmouseout="this.style.color='var(--sage)'"
        >
          · 分类浏览
        </a>
      </div>
      <h1 style="font-family:'Noto Serif SC',serif; font-size:2.5rem; font-weight:700; color:var(--brown); margin-bottom:1rem;">合集</h1>
      <div style="width:60px; height:3px; background:linear-gradient(to right,#f4a97f,#c96a3e); border-radius:2px;"></div>
    </div>

    <div id="masonry-container" style="position: relative;">
      {groupNames.map(name => {
        const { count, coverImage } = groupStats[name] || { count: 0, coverImage: null };
        return (
        <a
          href={`${basePath.endsWith('/') ? basePath : `${basePath}/`}groups/${encodeURIComponent(name)}`}
          style="display:block; text-decoration:none; background:var(--warm-white); border-radius:16px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,.06); transition:transform 0.25s,box-shadow 0.25s;"
          onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 10px 30px rgba(0,0,0,.1)'"
          onmouseout="this.style.transform='';this.style.boxShadow='0 2px 12px rgba(0,0,0,.06)'"
        >
          {coverImage && (
            <div style="width:100%; line-height: 0; overflow:hidden; background:var(--bg-secondary);">
              <img
                src={coverImage}
                alt={groupNamesMap[name] || name}
                style="width:100%; height:auto; display:block;"
              />
            </div>
          )}
          <div style={`padding:${coverImage ? '1rem 1rem 1.2rem' : '1.5rem'};`}>
            <div style="font-family:'Noto Serif SC',serif; font-size:1.25rem; font-weight:700; color:#5c3d2e; margin-bottom:0.5rem;">
              {groupNamesMap[name] || name}
            </div>
            <div style="font-size:0.85rem; color:#7a9e7e; display:flex; align-items:center; gap:0.3rem;">
              <span>{count || 0}</span>
              <span>篇文章</span>
            </div>
          </div>
        </a>
        );
      })}
    </div>
  </main>
</BaseLayout>

<script>
  // 加载 Masonry 实现真正的错落瀑布流（先行后列）- 响应式
  (function() {
    function getColumnCount() {
      const width = window.innerWidth;
      if (width >= 1200) {
        return 4; // 大屏：4列
      } else if (width >= 768) {
        return 3; // 桌面：3列
      } else if (width >= 480) {
        return 2; // 平板：2列
      } else {
        return 1; // 手机：1列
      }
    }

    function initMasonry() {
      const container = document.getElementById('masonry-container');
      if (!container) return;

      const items = Array.from(container.children);
      const columnCount = getColumnCount();
      const gap = 24; // 1.5rem = 24px

      // 计算每列宽度
      const containerWidth = container.clientWidth;
      const columnWidth = (containerWidth - (columnCount - 1) * gap) / columnCount;

      // 初始化每列高度
      const columnHeights = new Array(columnCount).fill(0);

      items.forEach((item) => {
        item.style.width = columnWidth + 'px';
        item.style.position = 'absolute';

        // 保持卡片原有顺序，依次放到当前高度最小的列中
        // 这样自动平衡高度：高列自然少放卡片，矮列多放，整体更均匀
        // 如果某一列因为长帖子变高了，后续卡片自动去更矮的列，正好满足需求
        const minHeight = Math.min(...columnHeights);
        const columnIndex = columnHeights.indexOf(minHeight);
        const top = minHeight;
        const left = columnIndex * (columnWidth + gap);

        item.style.left = left + 'px';
        item.style.top = top + 'px';

        // 更新列高度
        columnHeights[columnIndex] += item.offsetHeight + gap;
      });

      // 设置容器高度
      container.style.height = Math.max(...columnHeights) + 'px';
    }

    // DOM 就绪后立即布局，让用户尽快看到内容
    // 所有图片加载完成后再重新布局一次校正位置
    function runInitMasonry() {
      setTimeout(initMasonry, 0);
    }

    // 等待所有图片加载完成后重新布局确保高度正确
    function waitAllImagesAndRelayout() {
      const images = Array.from(document.querySelectorAll('#masonry-container img'));
      let loadedCount = 0;
      const totalImages = images.length;

      if (totalImages === 0) {
        initMasonry();
        return;
      }

      images.forEach(img => {
        if (img.complete) {
          loadedCount++;
          if (loadedCount === totalImages) {
            setTimeout(initMasonry, 0);
          }
        } else {
          img.addEventListener('load', () => {
            loadedCount++;
            if (loadedCount === totalImages) {
              setTimeout(initMasonry, 0);
            }
          });
          img.addEventListener('error', () => {
            loadedCount++;
            if (loadedCount === totalImages) {
              setTimeout(initMasonry, 0);
            }
          });
        }
      });

      // 超时保护，3秒后无论如何都重新布局
      setTimeout(() => {
        setTimeout(initMasonry, 0);
      }, 3000);
    }

    if (document.readyState === 'complete') {
      runInitMasonry();
      waitAllImagesAndRelayout();
    } else if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', runInitMasonry);
      window.addEventListener('load', waitAllImagesAndRelayout);
    } else {
      runInitMasonry();
      window.addEventListener('load', waitAllImagesAndRelayout);
    }

    // 窗口 resize 重新布局
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(initMasonry, 200);
    });

    // 屏幕旋转时重新布局（手机）
    window.addEventListener('orientationchange', () => {
      setTimeout(initMasonry, 200);
    });
  })();
</script>

<style>
  :root {
    --cream:#fdf6ec;--warm-white:#fffaf4;--peach:#f4a97f;
    --terracotta:#c96a3e;--sage:#7a9e7e;--sand:#e8d5b7;
    --brown:#5c3d2e;--text-main:#3a2518;--text-muted:#7a5c47;
  }
</style>
