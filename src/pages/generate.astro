---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="AI绘画 · 李春晓" description="AI 图像生成工具，上传参考图描述你的想法，AI 帮你生成图片">
  <main style="max-width: 800px; margin: 0 auto; padding: 8rem 2rem 5rem;">
    <div class="reveal">
      <div class="page-header">
        <div class="section-tag">// AI 创作</div>
        <h1 class="page-title">AI 绘画生成</h1>
        <div class="section-divider"></div>
        <p class="page-description">上传参考图（可选），描述你的想法，AI 帮你生成专业的绘画作品。</p>
      </div>

      <!-- Gallery Section -->
      <div class="card gallery-container">
        <div class="gallery-header">
          <label class="label">作品展示</label>
          <span class="gallery-subtitle">点击图片可查看详情</span>
        </div>
        <div class="gallery-grid">
          <div class="gallery-item" data-image="/gen/chan.jpg">
            <img src="/gen/chan.jpg" alt="AI作品 - 蝉" loading="lazy">
            <div class="gallery-overlay">
              <span class="gallery-title">蝉 · 夏日</span>
            </div>
          </div>
          <div class="gallery-item" data-image="/gen/lcx.jpg">
            <img src="/gen/lcx.jpg" alt="AI作品 - 春晓" loading="lazy">
            <div class="gallery-overlay">
              <span class="gallery-title">春晓 · 诗意</span>
            </div>
          </div>
          <div class="gallery-item" data-image="/gen/mama.jpg">
            <img src="/gen/mama.jpg" alt="AI作品 - 妈妈" loading="lazy">
            <div class="gallery-overlay">
              <span class="gallery-title">妈妈 · 温柔</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Gallery Lightbox -->
      <div id="lightbox" class="lightbox" style="display: none;">
        <div class="lightbox-content">
          <button id="lightboxClose" class="lightbox-close">&times;</button>
          <img id="lightboxImage" src="" alt="">
        </div>
      </div>

      <!-- Image Upload Area -->
      <div class="card upload-container">
        <label class="label">参考图片</label>
        <div id="dropZone" class="drop-zone">
          <input type="file" id="fileInput" accept="image/*" hidden>
          <div id="uploadPlaceholder">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <circle cx="8.5" cy="8.5" r="1.4"></circle>
              <polyline points="21 15 16 10 5 21"></polyline>
            </svg>
            <p>点击上传或将图片拖到此处</p>
          </div>
          <div id="imagePreview" class="image-preview" style="display: none;"></div>
        </div>
        <button id="clearBtn" class="btn-secondary" style="display: none; margin-top: 1rem;">清除图片</button>
      </div>

      <!-- Requirements Input -->
      <div class="card input-container">
        <label class="label" for="requirementsInput">创作要求</label>
        <textarea
          id="requirementsInput"
          class="textarea"
          placeholder="描述你想要生成的图片，例如：一只穿着毛衣的猫在雨中散步，日系风格..."
          rows="4"
        ></textarea>
        <div class="example-container">
          <span class="example-label">示例：</span>
          <button id="fillExampleBtn" class="btn-example">将照片中的人物切换成Q风格，改成人物在美丽风景旁边写生的场景，景色优秀，画面和谐</button>
        </div>
      </div>

      <!-- Generate Prompt Button -->
      <div class="button-container">
        <button id="generatePromptBtn" class="btn-primary">
          生成 Prompt
        </button>
      </div>

      <!-- Loading Indicator for Prompt Generation -->
      <div id="loadingPrompt" class="loading" style="display: none;">
        <div class="spinner"></div>
        <p>正在生成 Prompt，请稍候...</p>
      </div>

      <!-- Generated Prompt -->
      <div class="card prompt-container">
        <div class="prompt-header">
          <label class="label" for="promptOutput">生成的 Prompt (可编辑)</label>
          <button id="copyPromptBtn" class="btn-sm" style="display: none;">复制</button>
        </div>
        <div class="textarea-resize-wrapper">
          <textarea
            id="promptOutput"
            class="textarea"
            placeholder="生成的 English prompt 会显示在这里..."
            rows="3"
            readonly
          ></textarea>
          <div class="resize-handle" title="拖动调整高度">
            <svg width="16" height="4" viewBox="0 0 16 4" fill="currentColor">
              <circle cx="2" cy="2" r="1.5"/>
              <circle cx="8" cy="2" r="1.5"/>
              <circle cx="14" cy="2" r="1.5"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Image Generation Model Selection -->
      <div class="card model-select-container">
        <label class="label" for="modelSelect">生成模型</label>
        <select id="modelSelect" class="select-input">
          <option value="volcseed">Doubao Seed (火山引擎)</option>
          <option value="nanobanana">Nano Banana</option>
          <option value="siliconflow">SiliconFlow</option>
        </select>
      </div>

      <!-- Generate Image Button -->
      <div class="button-container">
        <button id="generateImageBtn" class="btn-primary" disabled>
          生成图片
        </button>
      </div>

      <!-- Loading Indicator for Image Generation -->
      <div id="loadingImage" class="loading" style="display: none;">
        <div class="spinner"></div>
        <p>正在生成图片，请稍候...</p>
      </div>

      <!-- Generated Image Result -->
      <div class="card result-container">
        <label class="label">生成结果</label>
        <div id="resultPlaceholder" class="result-placeholder">
          <p>生成的图片会显示在这里</p>
        </div>
        <div id="resultImageWrapper" class="result-image-wrapper" style="display: none;">
          <div id="resultImage" class="result-image"></div>
        </div>
        <div style="margin-top: 1rem;">
          <button id="downloadBtn" class="btn-secondary" style="display: none;">下载图片</button>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  :root {
    --cream: #fdf6ec;
    --warm-white: #fffaf4;
    --peach: #f4a97f;
    --terracotta: #c96a3e;
    --rust: #9b4422;
    --sage: #7a9e7e;
    --sage-light: #b8d4bb;
    --sand: #e8d5b7;
    --sand-dark: #c9b090;
    --brown: #5c3d2e;
    --text-main: #3a2518;
    --text-muted: #7a5c47;
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .section-tag {
    font-family: 'Caveat', cursive;
    font-size: 1.2rem;
    color: var(--sage);
    margin-bottom: 0.5rem;
  }

  .page-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--brown);
    margin-bottom: 1rem;
  }

  .section-divider {
    width: 60px;
    height: 3px;
    background: linear-gradient(to right, var(--peach), var(--terracotta));
    border-radius: 2px;
    margin-bottom: 1rem;
  }

  .page-description {
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 1.05rem;
  }

  .card {
    background: var(--warm-white);
    border-radius: 20px;
    padding: 1.8rem 2rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .label {
    display: block;
    font-family: 'Noto Serif SC', serif;
    font-weight: 600;
    color: var(--brown);
    margin-bottom: 0.8rem;
    font-size: 0.95rem;
  }

  .drop-zone {
    border: 2px dashed var(--sand);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    background: var(--cream);
  }

  .drop-zone.has-image {
    padding: 0.5rem;
  }

  .drop-zone.drag-over {
    border-color: var(--terracotta);
    background: var(--warm-white);
  }

  .drop-zone svg {
    color: var(--sand-dark);
    margin-bottom: 1rem;
  }

  .drop-zone p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  .image-preview {
    width: 100%;
    box-sizing: border-box;
    text-align: center;
    max-height: 70vh;
    overflow: auto;
    border-radius: 8px;
    scrollbar-width: thin;
    scrollbar-color: var(--sand) var(--cream);
  }

  .image-preview::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  .image-preview::-webkit-scrollbar-track {
    background: var(--cream);
    border-radius: 4px;
  }

  .image-preview::-webkit-scrollbar-thumb {
    background: var(--sand);
    border-radius: 4px;
  }

  .image-preview::-webkit-scrollbar-thumb:hover {
    background: var(--sand-dark);
  }

  .image-preview img {
    max-width: none;
    max-height: none;
    width: auto;
    height: auto;
    display: block;
    margin: 0 auto;
    border-radius: 8px;
    object-fit: contain;
    max-width: min(100%, 1200px);
  }

  @media (max-width: 768px) {
    .image-preview {
      max-height: 50vh;
    }
  }

  .textarea {
    width: 100%;
    background: var(--cream);
    border: 1.5px solid var(--sand);
    border-radius: 12px;
    padding: 0.8rem 1rem;
    color: var(--text-main);
    font-family: 'Lora', 'Noto Serif SC', serif;
    font-size: 1rem;
    line-height: 1.5;
    resize: vertical;
    transition: border-color 0.3s ease;
  }

  .textarea:focus {
    outline: none;
    border-color: var(--terracotta);
  }

  .textarea:readonly {
    color: var(--text-muted);
  }

  .example-container {
    margin-top: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .example-label {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .btn-example {
    background: var(--sage-light);
    color: var(--sage);
    border: none;
    border-radius: 8px;
    padding: 0.4rem 0.8rem;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-example:hover {
    background: var(--sage);
    color: white;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .textarea-resize-wrapper {
    position: relative;
  }

  .textarea-resize-wrapper .textarea {
    resize: none;
    padding-bottom: 24px;
  }

  .resize-handle {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 32px;
    height: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--sand);
    border-radius: 6px;
    cursor: ns-resize;
    color: var(--sand-dark);
    transition: all 0.2s ease;
    user-select: none;
  }

  .resize-handle:hover {
    background: var(--sand-dark);
    color: var(--brown);
    transform: translateX(-50%) scale(1.1);
  }

  .resize-handle:active {
    background: var(--terracotta);
    color: white;
  }

  .resize-handle svg {
    pointer-events: none;
  }

  .button-container {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .btn-primary {
    background: var(--terracotta);
    color: white;
    border: none;
    border-radius: 12px;
    padding: 0.9rem 2.5rem;
    font-family: 'Noto Serif SC', serif;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    min-height: 48px;
  }

  .btn-primary:hover:not(:disabled) {
    background: var(--rust);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(201, 106, 62, 0.3);
  }

  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-secondary {
    background: var(--sand);
    color: var(--brown);
    border: none;
    border-radius: 12px;
    padding: 0.7rem 1.8rem;
    font-family: 'Noto Serif SC', serif;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.3s ease;
    min-height: 40px;
  }

  .btn-secondary:hover {
    background: var(--sand-dark);
  }

  .btn-sm {
    background: var(--sage-light);
    color: var(--sage);
    border: none;
    border-radius: 8px;
    padding: 0.4rem 0.8rem;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-sm:hover {
    background: var(--sage);
    color: white;
  }

  .gallery-container {
    margin-bottom: 2rem;
  }

  .gallery-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .gallery-subtitle {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .gallery-item {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 1;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .gallery-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
    padding: 1.5rem 1rem 1rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-title {
    color: white;
    font-family: 'Noto Serif SC', serif;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .lightbox {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.9);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .lightbox-content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
  }

  .lightbox-content img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 8px;
  }

  .lightbox-close {
    position: absolute;
    top: -3rem;
    right: 0;
    background: none;
    border: none;
    color: white;
    font-size: 2.5rem;
    cursor: pointer;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
  }

  .lightbox-close:hover {
    transform: scale(1.2);
  }

  .model-select-container {
    margin-bottom: 1.5rem;
  }

  .select-input {
    width: 100%;
    background: var(--cream);
    border: 1.5px solid var(--sand);
    border-radius: 12px;
    padding: 0.8rem 1rem;
    color: var(--text-main);
    font-family: 'Lora', 'Noto Serif SC', serif;
    font-size: 1rem;
    cursor: pointer;
    transition: border-color 0.3s ease;
  }

  .select-input:focus {
    outline: none;
    border-color: var(--terracotta);
  }

  .loading {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .loading p {
    color: var(--text-muted);
    margin-top: 0.8rem;
  }

  .spinner {
    width: 40px;
    height: 40px;
    margin: 0 auto;
    border: 3px solid var(--sand);
    border-top-color: var(--terracotta);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .result-placeholder {
    background: var(--cream);
    border-radius: 12px;
    padding: 3rem 2rem;
    text-align: center;
  }

  .result-placeholder p {
    color: var(--text-muted);
    margin: 0;
  }

  .result-image-wrapper {
    width: 100%;
    max-height: 70vh;
    overflow: auto;
    border-radius: 12px;
    scrollbar-width: thin;
    scrollbar-color: var(--sand) var(--cream);
    background: var(--cream);
  }

  .result-image-wrapper::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  .result-image-wrapper::-webkit-scrollbar-track {
    background: var(--cream);
    border-radius: 4px;
  }

  .result-image-wrapper::-webkit-scrollbar-thumb {
    background: var(--sand);
    border-radius: 4px;
  }

  .result-image-wrapper::-webkit-scrollbar-thumb:hover {
    background: var(--sand-dark);
  }

  .result-image {
    width: 100%;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .result-image img {
    max-width: min(100%, 1200px);
    max-height: none;
    width: auto;
    height: auto;
    display: block;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  @media (max-width: 768px) {
    main {
      padding: 7rem 1.5rem 4rem !important;
    }

    .page-title {
      font-size: 2rem;
    }

    .card {
      padding: 1.3rem 1.5rem;
    }

    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.8rem;
    }

    .gallery-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
    }

    .lightbox-close {
      top: -2.5rem;
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    main {
      padding: 6rem 1rem 3rem !important;
    }

    .page-title {
      font-size: 1.75rem;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // State
  let uploadedImage = null;
  let generatedImageUrl = null;

  // Wait for DOM to be ready
  document.addEventListener('DOMContentLoaded', function() {
    // DOM Elements
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const uploadPlaceholder = document.getElementById('uploadPlaceholder');
    const imagePreview = document.getElementById('imagePreview');
    const clearBtn = document.getElementById('clearBtn');
    const requirementsInput = document.getElementById('requirementsInput');
    const fillExampleBtn = document.getElementById('fillExampleBtn');
    const generatePromptBtn = document.getElementById('generatePromptBtn');
    const promptOutput = document.getElementById('promptOutput');
    const copyPromptBtn = document.getElementById('copyPromptBtn');
    const modelSelect = document.getElementById('modelSelect');
    const generateImageBtn = document.getElementById('generateImageBtn');
    const loadingPrompt = document.getElementById('loadingPrompt');
    const loadingImage = document.getElementById('loadingImage');
    const resultPlaceholder = document.getElementById('resultPlaceholder');
    const resultImage = document.getElementById('resultImage');
    const downloadBtn = document.getElementById('downloadBtn');
    const lightbox = document.getElementById('lightbox');
    const lightboxImage = document.getElementById('lightboxImage');
    const lightboxClose = document.getElementById('lightboxClose');
    const galleryItems = document.querySelectorAll('.gallery-item');
    const resultImageWrapper = document.getElementById('resultImageWrapper');

    // Check if required elements exist
    if (!dropZone || !fileInput || !uploadPlaceholder || !imagePreview || !clearBtn) {
      console.error('Required upload elements not found');
      return;
    }

    // Image Upload Handlers
    dropZone.addEventListener('click', function() {
      fileInput.click();
    });

    dropZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.stopPropagation();
      if (e.dataTransfer) {
        e.dataTransfer.dropEffect = 'copy';
      }
      dropZone.classList.add('drag-over');
    });

    dropZone.addEventListener('dragenter', function(e) {
      e.preventDefault();
      e.stopPropagation();
      dropZone.classList.add('drag-over');
    });

    dropZone.addEventListener('dragleave', function(e) {
      e.preventDefault();
      e.stopPropagation();
      if (!dropZone.contains(e.relatedTarget)) {
        dropZone.classList.remove('drag-over');
      }
    });

    dropZone.addEventListener('drop', function(e) {
      e.preventDefault();
      e.stopPropagation();
      dropZone.classList.remove('drag-over');
      const files = e.dataTransfer?.files;
      if (files && files.length > 0) {
        handleFile(files[0]);
      }
    });

    fileInput.addEventListener('change', function() {
      if (fileInput.files && fileInput.files.length > 0) {
        handleFile(fileInput.files[0]);
      }
    });

    function handleFile(file) {
      if (!file.type.startsWith('image/')) {
        alert('请上传图片文件');
        return;
      }

      const img = new Image();
      const reader = new FileReader();

      reader.onload = function(e) {
        img.src = e.target.result;
      };

      img.onload = function() {
        const maxWidth = 1200;
        const maxHeight = 1200;
        let width = img.width;
        let height = img.height;

        if (width > maxWidth || height > maxHeight) {
          const ratio = Math.min(maxWidth / width, maxHeight / height);
          width = Math.round(width * ratio);
          height = Math.round(height * ratio);
        }

        const canvas = document.createElement('canvas');
        canvas.width = width;
        canvas.height = height;

        const ctx = canvas.getContext('2d');
        if (ctx) {
          ctx.drawImage(img, 0, 0, width, height);
          uploadedImage = canvas.toDataURL('image/jpeg', 0.8);
          showImagePreview(uploadedImage);
        } else {
          uploadedImage = img.src;
          showImagePreview(uploadedImage);
        }
      };

      reader.readAsDataURL(file);
    }

    function showImagePreview(imageUrl) {
      imagePreview.innerHTML = '<img src="' + imageUrl + '" alt="预览">';
      imagePreview.style.display = 'block';
      uploadPlaceholder.style.display = 'none';
      clearBtn.style.display = 'inline-block';
      dropZone.classList.add('has-image');

      if (imagePreview) {
        enableDragToScroll(imagePreview);
      }
    }

    // Resize handle functionality
    function initResizeHandle() {
      const resizeHandle = document.querySelector('.resize-handle');
      const textarea = document.getElementById('promptOutput');
      if (!resizeHandle || !textarea) return;

      let isResizing = false;
      let startY = 0;
      let startHeight = 0;

      const onMouseDown = function(e) {
        isResizing = true;
        const clientY = e instanceof MouseEvent ? e.clientY : e.touches[0].clientY;
        startY = clientY;
        startHeight = textarea.clientHeight;
        document.body.style.cursor = 'ns-resize';
        document.body.style.userSelect = 'none';
        e.preventDefault();
      };

      const onMouseMove = function(e) {
        if (!isResizing) return;
        const clientY = e instanceof MouseEvent ? e.clientY : e.touches[0].clientY;
        const deltaY = clientY - startY;
        const newHeight = Math.max(60, Math.min(400, startHeight + deltaY));
        textarea.style.height = newHeight + 'px';
        e.preventDefault();
      };

      const onMouseUp = function() {
        if (isResizing) {
          isResizing = false;
          document.body.style.cursor = '';
          document.body.style.userSelect = '';
        }
      };

      resizeHandle.addEventListener('mousedown', onMouseDown);
      resizeHandle.addEventListener('touchstart', onMouseDown, { passive: false });
      document.addEventListener('mousemove', onMouseMove);
      document.addEventListener('touchmove', onMouseMove, { passive: false });
      document.addEventListener('mouseup', onMouseUp);
      document.addEventListener('touchend', onMouseUp);
    }

    initResizeHandle();

    // Drag to scroll functionality
    function enableDragToScroll(element) {
      let isDown = false;
      let startX = 0;
      let startY = 0;
      let scrollLeft = 0;
      let scrollTop = 0;

      element.addEventListener('mousedown', function(e) {
        const img = element.querySelector('img');
        if (!img) return;
        if (img.naturalWidth <= element.clientWidth && img.naturalHeight <= element.clientHeight) return;

        isDown = true;
        element.style.cursor = 'grabbing';
        element.style.userSelect = 'none';
        startX = e.pageX - element.offsetLeft;
        startY = e.pageY - element.offsetTop;
        scrollLeft = element.scrollLeft;
        scrollTop = element.scrollTop;
      });

      element.addEventListener('mouseleave', function() {
        if (isDown) {
          isDown = false;
          element.style.cursor = 'default';
          element.style.userSelect = '';
        }
      });

      element.addEventListener('mouseup', function() {
        isDown = false;
        element.style.cursor = 'default';
        element.style.userSelect = '';
      });

      element.addEventListener('mousemove', function(e) {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - element.offsetLeft;
        const y = e.pageY - element.offsetTop;
        const walkX = (x - startX);
        const walkY = (y - startY);
        element.scrollLeft = scrollLeft - walkX;
        element.scrollTop = scrollTop - walkY;
      });

      element.addEventListener('touchstart', function(e) {
        const touch = e.touches[0];
        const img = element.querySelector('img');
        if (!img) return;
        if (img.naturalWidth <= element.clientWidth && img.naturalHeight <= element.clientHeight) return;

        isDown = true;
        startX = touch.pageX - element.offsetLeft;
        startY = touch.pageY - element.offsetTop;
        scrollLeft = element.scrollLeft;
        scrollTop = element.scrollTop;
      }, { passive: true });

      element.addEventListener('touchend', function() {
        isDown = false;
      });

      element.addEventListener('touchmove', function(e) {
        if (!isDown) return;
        const touch = e.touches[0];
        const x = touch.pageX - element.offsetLeft;
        const y = touch.pageY - element.offsetTop;
        const walkX = (x - startX);
        const walkY = (y - startY);
        element.scrollLeft = scrollLeft - walkX;
        element.scrollTop = scrollTop - walkY;
      }, { passive: true });
    }

    if (clearBtn) {
      clearBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        uploadedImage = null;
        fileInput.value = '';
        imagePreview.style.display = 'none';
        uploadPlaceholder.style.display = 'block';
        clearBtn.style.display = 'none';
        dropZone.classList.remove('has-image');
      });
    }

    // Fill Example Handler
    if (fillExampleBtn && requirementsInput) {
      fillExampleBtn.addEventListener('click', function() {
        requirementsInput.value = '将照片中的人物切换成Q风格，改成人物在美丽风景旁边写生的场景，景色优秀，画面和谐';
      });
    }

    // Generate Prompt Handler
    if (generatePromptBtn && requirementsInput && promptOutput && copyPromptBtn && generateImageBtn && loadingPrompt) {
      generatePromptBtn.addEventListener('click', async function() {
        const userInput = requirementsInput.value.trim();
        if (!userInput) {
          alert('请先输入创作要求');
          return;
        }

        loadingPrompt.style.display = 'block';
        generatePromptBtn.disabled = true;

        try {
          const response = await fetch('/api/generate-prompt', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userInput: userInput })
          });

          if (!response.ok) {
            let errorMessage = '生成失败';
            try {
              const contentType = response.headers.get('content-type') || '';
              if (contentType.includes('application/json')) {
                const errorData = await response.json();
                errorMessage = errorData.message || errorMessage;
              } else {
                const text = await response.text();
                console.error('Non-JSON error response:', text);
                errorMessage = '服务器错误 (' + response.status + ')，请检查开发服务器是否运行';
              }
            } catch (e) {
              console.error('Error parsing error response:', e);
              errorMessage = '服务器错误 (' + response.status + ')';
            }
            throw new Error(errorMessage);
          }

          const data = await response.json();
          promptOutput.value = data.prompt;
          promptOutput.readOnly = false;
          copyPromptBtn.style.display = 'inline-block';
          generateImageBtn.disabled = false;
        } catch (error) {
          console.error('Generate prompt error:', error);
          alert('生成 Prompt 失败: ' + error.message);
        } finally {
          loadingPrompt.style.display = 'none';
          generatePromptBtn.disabled = false;
        }
      });
    }

    // Copy Prompt Handler
    if (copyPromptBtn && promptOutput) {
      copyPromptBtn.addEventListener('click', async function() {
        try {
          await navigator.clipboard.writeText(promptOutput.value);
          const originalText = copyPromptBtn.textContent;
          copyPromptBtn.textContent = '已复制!';
          setTimeout(function() {
            copyPromptBtn.textContent = originalText;
          }, 1500);
        } catch (error) {
          alert('复制失败，请手动复制');
        }
      });
    }

    // Generate Image Handler
    if (generateImageBtn && promptOutput && modelSelect && loadingImage && resultImageWrapper && resultImage && resultPlaceholder && downloadBtn) {
      generateImageBtn.addEventListener('click', async function() {
        const prompt = promptOutput.value.trim();
        if (!prompt) {
          alert('请先生成 Prompt');
          return;
        }

        const provider = modelSelect.value;

        loadingImage.style.display = 'block';
        generateImageBtn.disabled = true;

        try {
          const response = await fetch('/api/generate-image', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              prompt: prompt,
              image: uploadedImage,
              provider: provider
            })
          });

          if (!response.ok) {
            let errorMessage = '生成图片失败';
            try {
              const contentType = response.headers.get('content-type') || '';
              if (contentType.includes('application/json')) {
                const error = await response.json();
                errorMessage = error.message || errorMessage;
              } else {
                const text = await response.text();
                console.error('Non-JSON error response:', text);
                errorMessage = '服务器错误 (' + response.status + ')，请检查开发服务器是否运行';
              }
            } catch (e) {
              console.error('Error parsing error response:', e);
              errorMessage = '服务器错误 (' + response.status + ')';
            }
            throw new Error(errorMessage);
          }

          const data = await response.json();

          if (data.imageUrl) {
            generatedImageUrl = data.imageUrl;
            displayImage(data.imageUrl);
          } else if (data.b64Json) {
            const b64 = 'data:image/png;base64,' + data.b64Json;
            generatedImageUrl = b64;
            displayImage(b64);
          }

          if (resultImageWrapper) {
            enableDragToScroll(resultImageWrapper);
          }
        } catch (error) {
          console.error('Generate image error:', error);
          alert('生成图片失败: ' + error.message);
        } finally {
          loadingImage.style.display = 'none';
          generateImageBtn.disabled = false;
        }
      });
    }

    function displayImage(imageUrl) {
      resultImage.innerHTML = '<img src="' + imageUrl + '" alt="生成结果">';
      resultImageWrapper.style.display = 'block';
      resultPlaceholder.style.display = 'none';
      downloadBtn.style.display = 'inline-block';

      if (resultImageWrapper) {
        enableDragToScroll(resultImageWrapper);
      }
    }

    // Download Handler
    if (downloadBtn) {
      downloadBtn.addEventListener('click', async function() {
        if (!generatedImageUrl) return;

        try {
          const response = await fetch(generatedImageUrl);
          const blob = await response.blob();
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'ai-generated-' + Date.now() + '.png';
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
        } catch (error) {
          window.open(generatedImageUrl, '_blank');
        }
      });
    }

    // Gallery Lightbox Handlers
    galleryItems.forEach(function(item) {
      item.addEventListener('click', function() {
        const imageUrl = item.getAttribute('data-image');
        if (imageUrl && lightbox && lightboxImage) {
          lightboxImage.src = imageUrl;
          lightbox.style.display = 'flex';
          document.body.style.overflow = 'hidden';
        }
      });
    });

    function closeLightbox() {
      if (lightbox) {
        lightbox.style.display = 'none';
        document.body.style.overflow = '';
      }
    }

    if (lightboxClose) {
      lightboxClose.addEventListener('click', closeLightbox);
    }

    if (lightbox) {
      lightbox.addEventListener('click', function(e) {
        if (e.target === lightbox) {
          closeLightbox();
        }
      });
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && lightbox && lightbox.style.display === 'flex') {
        closeLightbox();
      }
    });
  });
</script>
